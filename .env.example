# ── Core ──────────────────────────────────────────────────────────────────────
NDA_SKILL_PLAYBOOK_DIR=~/.nda-skill/playbook
NDA_SKILL_REVIEWER_NAME="Your Name"

# ── Notebook adapter (choose one: markdown | obsidian | notion | apple_notes) ─
NOTEBOOK_ADAPTER=markdown

# ── Markdown folder adapter ───────────────────────────────────────────────────
# Path to a local folder where playbook .md files will be copied
NOTEBOOK_MARKDOWN_PATH=~/Documents/Legal/NDA Playbook

# ── Obsidian adapter (leave blank if not using) ───────────────────────────────
# Requires the Obsidian Local REST API community plugin
# Note: self-signed cert is normal for local Obsidian — set OBSIDIAN_VERIFY_SSL=false
#       only if needed (localhost connections only)
OBSIDIAN_API_URL=https://127.0.0.1:27124
OBSIDIAN_API_KEY=
OBSIDIAN_VAULT_PATH=Legal/NDA Playbook
OBSIDIAN_VERIFY_SSL=true

# ── Notion adapter (leave blank if not using) ─────────────────────────────────
# Create an internal integration at https://www.notion.so/my-integrations
# Share the target database with the integration
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ── Apple Notes adapter (macOS only, no config needed) ────────────────────────
# Set NOTEBOOK_ADAPTER=apple_notes and notes will be created via AppleScript
# APPLE_NOTES_FOLDER=NDA Playbook
